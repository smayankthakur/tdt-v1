# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (for AI-powered message generation)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWATTER_NUMBER_ID=your-phone-number-id
TWILIO_WHATSAPP_NUMBER=+1234567890

# Optional: WhatsApp Meta API (alternative to Twilio)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages

# Optional: Status callback URL for Twilio webhooks
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/whatsapp/webhook

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WordPress Blog (SEO Content)
WORDPRESS_API_URL=https://blog.thedivinetarot.com/wp-json/wp/v2
WORDPRESS_USERNAME=your-admin-username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Razorpay Payment (India)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxx
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
