{
  "name": "divine-tarot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:env && npm run validate:i18n && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "check:imports": "eslint src --max-warnings=0",
    "graph": "madge --ts-config tsconfig.json --image graph.png src",
    "graph:check": "madge --circular --ts-config tsconfig.json src",
    "dep:heatmap": "dependency-cruise src | dot -T svg > depheatmap.svg",
    "barrels": "barrelsby --directory src --delete --location all --structure filesystem",
    "barrels:watch": "chokidar 'src/**/*.{ts,tsx}' -c 'npm run barrels'",
    "validate:arch": "npm run lint && npm run graph:check",
    "prepare": "husky || true",
    "design-audit": "node scripts/design-audit.js",
    "i18n:gen": "ts-node scripts/gen-i18n-types.ts",
    "i18n:check": "ts-node scripts/gen-i18n-types.ts",
    "validate:i18n": "node scripts/validateTranslations.js",
    "validate:env": "node scripts/validateEnv.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.103.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "razorpay": "^2.9.6",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.2",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^9.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run typecheck && npm run lint"
    }
  }
}
